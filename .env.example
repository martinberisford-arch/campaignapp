DATABASE_URL="postgresql://postgres:postgres@localhost:5432/charity_dashboard"
SESSION_SECRET="replace-with-long-random-string"

# Optional backward compatibility if you already set this in Vercel
NEXTAUTH_SECRET="replace-with-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional (only if you decide to add Redis/KV features later)
KV_REST_API_URL="https://<your-upstash-endpoint>.upstash.io"
KV_REST_API_TOKEN="<your-upstash-rest-token>"
KV_REST_API_READ_ONLY_TOKEN="<your-upstash-rest-readonly-token>"
KV_URL="rediss://default:<password>@<host>:6379"
REDIS_URL="rediss://default:<password>@<host>:6379"
